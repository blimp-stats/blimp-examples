SIMULATE:
	level_1(1) = 10 * 100;
	level_2(2) = 100;

	level_2:

		z  = normal(0, 1);
		u0 = normal(10 + z * -0.5,  1.0);
		u1 = normal(0.5, 0.2);
		u0 ~~ u1 := 0.2;
	level_1:
		x = normal(0, 1);
		y = normal(u0 + x * u1, 1);

VARIABLES: x y z level_2;
CLUSTERID: level_2;
MODEL: y ~ x z | x;
BURN: 10000;
ITER: 10000;
SEED: 198723;
SAVE: dataset = generated_data.csv;