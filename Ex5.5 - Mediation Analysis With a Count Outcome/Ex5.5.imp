DATA: data22.dat;
VARIABLES: id x v1:v4 m y v5 v6;
ORDINAL: x;
COUNT: y;
MISSING: 999;
MODEL:
  m ~ 1@m_icept x@alpha;
  y ~ 1@y_icept m@beta x@tau;
PARAMETERS:
  x0 = 0;
  x1 = 1;
  ab_at_x0 = alpha * (beta*exp(y_icept + beta*m_icept + tau*x0));
  ab_at_x1 = alpha * (beta*exp(y_icept + beta*(m_icept + alpha*x1) + tau*x1));
SEED: 90291;
BURN: 10000;
ITER: 10000;