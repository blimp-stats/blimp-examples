SIMULATE: n = 1000;

	define:
		f1 ~~ f2 = 0.3;
		rel_1 = 0.7;
		rel_2 = 0.8;

		v_1 = (1 / rel_1) - 1;
		v_2 = (1 / rel_2) - 1;

	n:
		f1:f2 = normal(0, 1);

		y1_1:y1_5 = normal(f1, v_1);
		y2_1:y2_5 = normal(f2, v_2);

VARIABLES: y1_1:y1_5 y2_1:y2_5;
LATENT: factor1 factor2;
MODEL:
  factor_model:
  factor1 ~~ factor2;
  items_model:
  factor1 -> y1_1:y1_5;
  factor2 -> y2_1:y2_5;

BURN: 10000;
ITER: 10000;
SEED: 10972;
SAVE: dataset = generated_data.csv;